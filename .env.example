# Copy this file to .env and fill in real values locally.
# Never commit real API keys.

APP_ENV=development
# Phase 49 recommends local PostgreSQL for development parity.
# SQLite remains a fallback/backup path and is still used by many isolated tests.
DATABASE_URL=sqlite:///./data/app.sqlite
RAW_DATA_DIR=data/raw
AUTH_ENABLED=false
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Production Docker Compose template. Copy values to .env.prod and fill secrets locally.
# Do not commit .env.prod.
APP_PORT=8000
POSTGRES_DB=rfc_rag
POSTGRES_USER=rfc_user
POSTGRES_PASSWORD=
REDIS_PASSWORD=
# DATABASE_URL is assembled by docker-compose.prod.yml from the PostgreSQL values above.
# For local PostgreSQL development, see .env.dev.example and docker-compose.dev.yml.
# Optional build mirror for servers with slow PyPI access.
PIP_INDEX_URL=
PIP_TRUSTED_HOST=

# Optional Redis runtime features. Redis Stack is required for real
# LangGraph RedisSaver checkpoints and Semantic Cache vector search.
# Use redis://:<url-encoded-password>@host:6379/0 when Redis AUTH is enabled.
REDIS_URL=
LANGGRAPH_CHECKPOINT_TTL_MINUTES=60
LANGGRAPH_CHECKPOINT_REFRESH_ON_READ=true
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_TTL_SECONDS=3600
# Phase 56 layered Agent cache. These caches store derived ids/order/scores
# and hydrate source text from the database at request time. Enabled by default
# after Phase 57 human verification. Keep answer-level SEMANTIC_CACHE_ENABLED=false
# unless a narrower rollout is explicitly approved.
LAYERED_CACHE_NAMESPACE=phase56-v1
RETRIEVAL_CANDIDATE_CACHE_ENABLED=true
RETRIEVAL_CANDIDATE_CACHE_TTL_SECONDS=900
RERANK_ORDER_CACHE_ENABLED=true
RERANK_ORDER_CACHE_TTL_SECONDS=900
TOOL_RESULT_CACHE_ENABLED=true
TOOL_RESULT_CACHE_TTL_SECONDS=900
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_WINDOW_SECONDS=60
PGVECTOR_SEARCH_ENABLED=true
HNSW_EF_SEARCH=100

# Chat model provider. Leave blank for deterministic/local-only development where supported.
CHAT_MODEL_PROVIDER=
CHAT_MODEL_NAME=
CHAT_MODEL_API_KEY=
CHAT_MODEL_BASE_URL=
CHAT_MODEL_TEMPERATURE=0.2
CHAT_MODEL_TIMEOUT_SECONDS=30

# Dedicated planner provider for production ReAct and LangGraph planning.
# Use a fast non-reasoning or low-latency model for action routing; keep
# CHAT_MODEL_* as the stronger final-answer model. Tests clear these values
# in tests/conftest.py so CI remains deterministic and never calls this API.
PLANNER_CHAT_MODEL_PROVIDER=openai-compatible
PLANNER_CHAT_MODEL_NAME=deepseek-v4-flash
PLANNER_CHAT_MODEL_API_KEY=
# Optional comma-separated pool for extraction throughput; leave blank unless
# you intentionally want worker requests to round-robin across multiple keys.
PLANNER_CHAT_MODEL_API_KEYS=
PLANNER_CHAT_MODEL_BASE_URL=
PLANNER_CHAT_MODEL_TEMPERATURE=0
PLANNER_CHAT_MODEL_TIMEOUT_SECONDS=10

# Judge model for evaluation scripts (Phase 54+). Use a stronger model than
# flash for scoring accuracy, completeness, and citation quality.
JUDGE_MODEL_PROVIDER=openai-compatible
JUDGE_MODEL_NAME=GLM-5.2
JUDGE_MODEL_API_KEY=
JUDGE_MODEL_BASE_URL=https://llmapi.paratera.com
JUDGE_MODEL_TEMPERATURE=0
JUDGE_MODEL_TIMEOUT_SECONDS=30

EMBEDDING_PROVIDER=
EMBEDDING_MODEL_NAME=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSION=0
EMBEDDING_TIMEOUT_SECONDS=30

RERANKING_ENABLED=true
RERANKING_PROVIDER=remote-bge-lora
RERANKING_MODEL_NAME=rfc-domain-bge-lora
RERANKING_API_KEY=
# Local/evaluation default only. In production Docker, 127.0.0.1 means the
# app container itself. When BGE runs on a separate GPU server, set this to a
# container-reachable private GPU/VPN URL or a compose sidecar tunnel URL.
RERANKING_BASE_URL=http://127.0.0.1:8091
RERANKING_TIMEOUT_SECONDS=30
RERANKING_RECALL_K=75
RERANKING_DYNAMIC_TOP_K_ENABLED=true
RERANKING_DYNAMIC_MIN_RESULTS=4
RERANKING_DYNAMIC_MAX_RESULTS=12
RERANKING_DYNAMIC_RELATIVE_SCORE_THRESHOLD=0.65
RERANKING_FALLBACK_ENABLED=true
RERANKING_FALLBACK_PROVIDER=zhipu
RERANKING_FALLBACK_MODEL_NAME=rerank
RERANKING_FALLBACK_API_KEY=
RERANKING_FALLBACK_BASE_URL=https://open.bigmodel.cn/api/paas/v4
RERANKING_FALLBACK_TIMEOUT_SECONDS=30
GRAPHRAG_GRAPH_PATH=data/knowledge_graph/domain_graph.json

# Phase 57 multi-channel hybrid retrieval kernel. Enabled by default after
# real default-chain evaluation and user human verification passed.
HYBRID_MULTICHANNEL_ENABLED=true
HYBRID_GRAPH_CHANNEL_ENABLED=true
HYBRID_TABLE_TEXT_CHANNEL_ENABLED=true
HYBRID_FIGURE_CAPTION_CHANNEL_ENABLED=true
HYBRID_CHANNEL_RANK_CONSTANT=60
HYBRID_GRAPH_CHANNEL_WEIGHT=1.1
HYBRID_TABLE_TEXT_CHANNEL_WEIGHT=0.9
HYBRID_FIGURE_CAPTION_CHANNEL_WEIGHT=0.8
HYBRID_GRAPH_MAX_MATCHES=75

# Fallback-only local reranker for offline tests or emergency rollback.
# RERANKING_PROVIDER=deterministic
# RERANKING_MODEL_NAME=keyword-overlap-reranker-v1
# RERANKING_BASE_URL=
# RERANKING_RECALL_K=25

# Vision model provider. Leave blank for deterministic/local-only tests.
VISION_MODEL_PROVIDER=
VISION_MODEL_NAME=
VISION_MODEL_API_KEY=
VISION_MODEL_BASE_URL=
VISION_MODEL_TIMEOUT_SECONDS=30
