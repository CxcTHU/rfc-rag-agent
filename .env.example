# Copy this file to .env and fill in real values locally.
# Never commit real API keys.

APP_ENV=development
DATABASE_URL=sqlite:///./data/app.sqlite
RAW_DATA_DIR=data/raw
AUTH_ENABLED=false
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Production Docker Compose template. Copy values to .env.prod and fill secrets locally.
# Do not commit .env.prod.
APP_PORT=8000
POSTGRES_DB=rfc_rag
POSTGRES_USER=rfc_user
POSTGRES_PASSWORD=
# DATABASE_URL is assembled by docker-compose.prod.yml from the PostgreSQL values above.
# Optional build mirror for servers with slow PyPI access.
PIP_INDEX_URL=
PIP_TRUSTED_HOST=

# Chat model provider. Leave blank for deterministic/local-only development where supported.
CHAT_MODEL_PROVIDER=
CHAT_MODEL_NAME=
CHAT_MODEL_API_KEY=
CHAT_MODEL_BASE_URL=
CHAT_MODEL_TEMPERATURE=0.2
CHAT_MODEL_TIMEOUT_SECONDS=30

# Optional dedicated planner provider for ReAct planning.
PLANNER_CHAT_MODEL_PROVIDER=
PLANNER_CHAT_MODEL_NAME=
PLANNER_CHAT_MODEL_API_KEY=
PLANNER_CHAT_MODEL_BASE_URL=
PLANNER_CHAT_MODEL_TEMPERATURE=0
PLANNER_CHAT_MODEL_TIMEOUT_SECONDS=30

EMBEDDING_PROVIDER=
EMBEDDING_MODEL_NAME=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSION=0
EMBEDDING_TIMEOUT_SECONDS=30

RERANKING_ENABLED=true
RERANKING_PROVIDER=deterministic
RERANKING_MODEL_NAME=keyword-overlap-reranker-v1
RERANKING_API_KEY=
RERANKING_BASE_URL=
RERANKING_TIMEOUT_SECONDS=30
RERANKING_RECALL_K=25

# Vision model provider. Leave blank for deterministic/local-only tests.
VISION_MODEL_PROVIDER=
VISION_MODEL_NAME=
VISION_MODEL_API_KEY=
VISION_MODEL_BASE_URL=
VISION_MODEL_TIMEOUT_SECONDS=30
