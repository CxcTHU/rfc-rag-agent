[Unit]
Description=RFC RAG provider local TCP forwarder for Docker app containers
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/rfc-rag-agent-stage44-smoke
Environment=PROVIDER_FORWARD_LISTEN_HOST=172.18.0.1
ExecStart=/usr/bin/python3 %h/rfc-rag-agent-stage44-smoke/scripts/ops/provider_tcp_forward.py
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
