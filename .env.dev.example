# Copy selected values to .env for local PostgreSQL development.
# Example-only password; replace it locally if the database is reachable beyond localhost.

APP_ENV=development
DATABASE_URL=postgresql+psycopg2://rfc_user:dev_password@localhost:5433/rfc_rag_dev
REDIS_URL=redis://:dev_redis_password@localhost:6379/0
LANGGRAPH_CHECKPOINT_TTL_MINUTES=60
LANGGRAPH_CHECKPOINT_REFRESH_ON_READ=true
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_TTL_SECONDS=3600
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_WINDOW_SECONDS=60
PGVECTOR_SEARCH_ENABLED=true
HNSW_EF_SEARCH=100
RAW_DATA_DIR=data/raw
AUTH_ENABLED=false
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional planner fast model for react_agent/langgraph_agent route decisions.
# Leave blank for deterministic planner fallback in local development.
# PLANNER_CHAT_MODEL_PROVIDER=openai-compatible
# PLANNER_CHAT_MODEL_NAME=deepseek-v4-flash
# PLANNER_CHAT_MODEL_BASE_URL=
# PLANNER_CHAT_MODEL_TEMPERATURE=0
# PLANNER_CHAT_MODEL_TIMEOUT_SECONDS=10

POSTGRES_DB=rfc_rag_dev
POSTGRES_USER=rfc_user
POSTGRES_PASSWORD=dev_password
POSTGRES_DEV_PORT=5433
REDIS_PASSWORD=dev_redis_password
REDIS_DEV_PORT=6379
